# ── Core API ────────────────────────────────────────────────────────────────
PORT=8787
HOST=0.0.0.0
JWT_SECRET=change-me-in-prod
CORS_ORIGINS=http://localhost:5173
TRACKING_BASE_URL=http://localhost:8788

# Commission / payout defaults
DEFAULT_HOLD_DAYS=14
DEFAULT_MIN_PAYOUT_CENTS=5000
AUTO_APPROVE_CONVERSIONS=true

# ── Persistence (production) ─────────────────────────────────────────────────
# Default runtime is the in-memory store. Set USE_POSTGRES=true (or just provide
# DATABASE_URL) and the API, edge, and worker all share ONE Postgres-backed store.
# Back the ledger up OFF-BOX (PITR to R2/S3) — Section 11.
USE_POSTGRES=false
DATABASE_URL=postgres://vantage:vantage@localhost:5432/vantage
REDIS_URL=redis://redis:6379

# Production hardening
NODE_ENV=development          # in production, JWT_SECRET must NOT be the dev default (boot fails otherwise)
PUBLIC_API_URL=http://localhost:8787   # base for the unsubscribe link in outreach email
SCHEDULER=false               # set true to run the autonomous recruitment scheduler in-process (dev)

# ── Tracking edge (Cloudflare Workers) ───────────────────────────────────────
EDGE_PORT=8788
CLOUDFLARE_KV_NAMESPACE_ID=
CLOUDFLARE_ACCOUNT_ID=

# ── Email ────────────────────────────────────────────────────────────────────
# Recruitment sends go through the MERCHANT's connected mailbox (Gmail/MS Graph),
# never this box. Transactional mail goes through an ESP — NEVER the origin IP.
ESP_PROVIDER=resend
RESEND_API_KEY=
POSTMARK_SERVER_TOKEN=

# ── Scraping (Section 11 rule: rotating/residential proxies, never the box IP) ─
PROXY_URL=

# ── Payout rails (orchestration without custody) ─────────────────────────────
STRIPE_API_KEY=
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=
WISE_API_KEY=

# ── Enrichment / intelligence ────────────────────────────────────────────────
HUNTER_API_KEY=
ANTHROPIC_API_KEY=
