# ── Core API ────────────────────────────────────────────────────────────────
PORT=8787
HOST=0.0.0.0
JWT_SECRET=change-me-in-prod
CORS_ORIGINS=http://localhost:5173
TRACKING_BASE_URL=http://localhost:8788

# Commission / payout defaults
DEFAULT_HOLD_DAYS=14
DEFAULT_MIN_PAYOUT_CENTS=5000
AUTO_APPROVE_CONVERSIONS=true

# ── Persistence (production) ─────────────────────────────────────────────────
# Default runtime is the in-memory store. Set USE_POSTGRES=true (or just provide
# DATABASE_URL) and the API, edge, and worker all share ONE Postgres-backed store.
# Back the ledger up OFF-BOX (PITR to R2/S3) — Section 11.
USE_POSTGRES=false
DATABASE_URL=postgres://vantage:vantage@localhost:5432/vantage
REDIS_URL=redis://redis:6379

# Production hardening
NODE_ENV=development          # in production, JWT_SECRET must NOT be the dev default (boot fails otherwise)
PUBLIC_API_URL=http://localhost:8787   # base for the unsubscribe link in outreach email
SCHEDULER=false               # set true to run the autonomous recruitment scheduler in-process (dev)

# ── Tracking edge (Cloudflare Workers) ───────────────────────────────────────
EDGE_PORT=8788
CLOUDFLARE_KV_NAMESPACE_ID=
CLOUDFLARE_ACCOUNT_ID=

# ── Email ────────────────────────────────────────────────────────────────────
# Recruitment sends go through the MERCHANT's connected mailbox (Gmail/MS Graph),
# never this box. Transactional mail goes through an ESP — NEVER the origin IP.
ESP_PROVIDER=resend
RESEND_API_KEY=
POSTMARK_SERVER_TOKEN=

# ── Mailbox OAuth (connect a merchant's Gmail/Microsoft to send as them) ──────
# Register an app with each provider; set the redirect URI to
# {PUBLIC_API_URL}/oauth/microsoft/callback and .../oauth/google/callback.
# Microsoft Graph (delegated Mail.Send) needs NO security audit + works while unverified.
# Gmail send is a restricted scope (CASA) — use the SMTP app-password rail until then.
MS_OAUTH_CLIENT_ID=
MS_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# ── Scraping (Section 11 rule: rotating/residential proxies, never the box IP) ─
PROXY_URL=

# Headless-browser fetching for JS-rendered pages + to pass JS anti-bot challenges
# (e.g. Cloudflare "checking your browser"). When true, the page fetcher escalates
# from cheap static fetch → a real Playwright browser ONLY when a page looks
# blocked/empty/challenged (so you don't pay browser cost on every page). Requires:
#   npm install playwright && npx playwright install chromium
# CAPTCHA walls (Turnstile/hCaptcha) still need residential proxies to avoid, or a
# managed unblocker API behind the same fetcher port.
BROWSER_FETCH=false

# ── Payout rails (orchestration without custody) ─────────────────────────────
STRIPE_API_KEY=
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=
WISE_API_KEY=

# ── Discovery providers (find affiliates for real) ───────────────────────────
# ALL optional. With none set, discovery runs deterministic generators and labels
# the output "demo data" — it never fabricates real claims. Each is gated in
# packages/api/src/context.ts.

# Competitor backlink mining — THE WARMEST SOURCE + the recursive frontier / Niche Map.
# DataForSEO is pay-as-you-go (~$0.05 / 1k backlinks, ~100x cheaper than Ahrefs).
# login/password are the API credentials from the DataForSEO dashboard (the API
# password is separate from your account password). $100 min balance, shared across APIs.
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# Real SERP discovery (SerpApi/Serper). Also turns on the real page fetcher, redirect
# resolver, MX email verifier, and contact-link following. Without it SERP is synthetic.
SERPAPI_KEY=

# IG / TikTok / X public follower count + engagement via a scraping-API actor.
# Recommended pay-as-you-go vendors: ScrapeCreators or Social Fetch. SCRAPE_API_URL is
# the actor/profile endpoint; SCRAPE_API_KEY its token. Demographics deferred.
SCRAPE_API_URL=
SCRAPE_API_KEY=

# YouTube reach + engagement — FREE via the Data API (subs + recent-video engagement).
YOUTUBE_API_KEY=

# Allow the deterministic/demo discovery generators. Default: true outside production,
# FALSE in production (a deployed instance must never invent affiliates).
# ALLOW_SYNTHETIC_DISCOVERY=

# ── Enrichment / intelligence ────────────────────────────────────────────────
HUNTER_API_KEY=          # real email find/verify (fallback after page-extraction)
ANTHROPIC_API_KEY=       # real LLM (AI-SDR + outreach personalization), Claude Opus 4.8

# Relevance scoring uses a CHEAP, fast model to judge topical niche fit (semantic, not
# just keyword overlap). Precedence: RELEVANCE_LLM_* → ANTHROPIC_API_KEY (Haiku) → the
# offline lexical embedder. Set RELEVANCE_LLM_API_KEY to use any OpenAI-compatible
# budget model and point it wherever it's cheapest:
#   xAI Grok : RELEVANCE_LLM_BASE_URL=https://api.x.ai/v1         RELEVANCE_LLM_MODEL=grok-4-fast-non-reasoning
#   Groq     : RELEVANCE_LLM_BASE_URL=https://api.groq.com/openai/v1  RELEVANCE_LLM_MODEL=llama-3.3-70b-versatile
#   OpenAI   : RELEVANCE_LLM_BASE_URL=https://api.openai.com/v1   RELEVANCE_LLM_MODEL=gpt-4o-mini
# Base URL defaults to xAI Grok, model to grok-4-fast-non-reasoning, when only the key is set.
RELEVANCE_LLM_API_KEY=
RELEVANCE_LLM_BASE_URL=
RELEVANCE_LLM_MODEL=
